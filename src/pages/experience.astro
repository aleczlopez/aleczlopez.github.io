---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const [entry] = await getCollection("pages", ({ data }) => data.title === "Experience");
const { Content } = await entry.render();
---

<BaseLayout title="Experience — Alecz Lopez" description="Professional experience">
  <Header />

  <main class="flex-1">
    <article class="section">
      <div class="container-page">
        <a
          href="/"
          class="mb-8 inline-flex items-center gap-1 text-sm font-medium text-gray-500 hover:text-accent-600 transition-colors dark:text-gray-400 dark:hover:text-accent-400"
        >
          &larr; Back to home
        </a>

        <h1 class="heading-1 mb-10">Experience</h1>

        <div class="max-w-3xl prose prose-gray prose-headings:font-semibold prose-h2:mb-2 prose-h2:text-2xl prose-h3:mb-1 prose-h3:text-lg prose-h3:font-medium prose-p:mt-1 prose-p:mb-3 prose-p:text-sm prose-p:leading-relaxed prose-p:text-gray-500 prose-ul:mt-2 prose-ul:space-y-2 prose-li:text-sm prose-li:leading-relaxed prose-li:marker:text-accent-500 prose-code:rounded prose-code:bg-gray-100 prose-code:px-2 prose-code:py-0.5 prose-code:text-xs prose-code:font-normal prose-hr:my-8 dark:prose-invert dark:prose-code:bg-gray-800 dark:prose-strong:text-gray-100">
          <Content />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
