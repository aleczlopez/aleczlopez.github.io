---
export interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

<figure class="my-8">
  <div class="overflow-hidden rounded-lg border border-transparent bg-transparent p-4 sm:p-6 dark:border-transparent dark:bg-transparent">
    <div class="mermaid">
      <slot />
    </div>
  </div>
  {caption && (
    <figcaption class="mt-2 text-center text-sm text-gray-500 dark:text-gray-400">
      {caption}
    </figcaption>
  )}
</figure>
